# NIGHTSHIFT Configuration
# Copy to .env and set your paths

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Paths (defaults work if brain.db is in the same directory)
NIGHTSHIFT_TENANT=default
NIGHTSHIFT_BRAIN_DB=./brain.db
NIGHTSHIFT_BENCHMARK=./brain_benchmark.json
NIGHTSHIFT_LOG=./NIGHTSHIFT_LOG.md
NIGHTSHIFT_EOS_CLI=./sauron-cli.js
NIGHTSHIFT_ENV_FILE=./.env
